/*Создайте файл test1.txt со словом "Hello". Создайте жесткую ссылку hard1 
и символическую ссылку soft1 на этот файл. Напишите все команды, которые вы использовали.*/

# создаём файл test1.txt со словом "Hello"
echo "Hello" > test1.txt

# создаём жёсткую ссылку hard1 на test1.txt
ln test1.txt hard1

# создаём символическую ссылку soft1 на test1.txt
ln -s test1.txt soft1
