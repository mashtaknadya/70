/*Создайте новый файл с именем test1.txt и запишите в него "World". 
Напишите команду. Затем выполните cat hard1 и cat soft1. Запишите, что вывела каждая команда.*/

# создаём новый файл test1.txt с содержимым "World"
echo "World" > test1.txt

# читаем через жёсткую ссылку
cat hard1

# читаем через символическую ссылку
cat soft1


cat hard1 выведет "World" (потому что жёсткая ссылка указывает на тот же инод, который теперь содержит новое содержимое).
cat soft1 выведет "World" (потому что символическая ссылка указывает на имя test1.txt, а оно теперь связано с новым содержимым, если файл был перезаписан, а не удалён).

